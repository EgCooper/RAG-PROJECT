# Proveedor LLM: minimax | groq
LLM_PROVIDER=minimax

# MiniMax (https://platform.minimax.io)
MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY"
MINIMAX_LLM_MODEL=MiniMax-M2.7

# Groq (alternativa)
GROQ_API_KEY="YOUR_GROQ_API_KEY"
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Reranking (búsqueda híbrida; más lento, opcional)
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CANDIDATES=30

# Deduplicación de chunks en retrieval
DEDUP_ENABLED=true

# PostgreSQL (chats y sesiones)
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_ach
DEFAULT_USER_NAME=default

# Documentos (upload desde UI)
UPLOAD_MAX_MB=50
UPLOAD_BATCH_MAX_FILES=100
PENDING_UPLOAD_DIR=uploads/pending

# Acceso LAN (opcional). Ej: http://192.168.1.45:5173
# Por defecto ya se permiten IPs privadas 192.168.x / 10.x / 172.16-31.x en el puerto 5173.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
